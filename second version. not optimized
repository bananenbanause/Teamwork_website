function Avatar({ user, size = 36 }) {
  if (!user) return null;
  return (
    <div style={{
      width: size, height: size, borderRadius: "50%",
      background: user.color + "33", border: `2px solid ${user.color}55`,
      display: "flex", alignItems: "center", justifyContent: "center",
      color: user.color, fontWeight: 700, fontSize: size * 0.35,
      fontFamily: "'DM Sans', sans-serif", flexShrink: 0,
    }}>{user.avatar}</div>
  );
}

function ProgressBar({ value, color = COLORS.accent, thin = false }) {
  return (
    <div style={{ background: COLORS.border, borderRadius: 99, height: thin ? 4 : 8, overflow: "hidden" }}>
      <div style={{
        width: `${value}%`, height: "100%", borderRadius: 99,
        background: `linear-gradient(90deg, ${color}bb, ${color})`,
        boxShadow: `0 0 8px ${color}66`,
        transition: "width 0.8s cubic-bezier(.4,0,.2,1)",
      }} />
    </div>
  );
}

function FileIcon({ type }) {
  const map = {
    pdf: { icon: "📄", color: "#e74c3c" },
    zip: { icon: "📦", color: "#f7c74f" },
    doc: { icon: "📝", color: "#4f8ef7" },
    xls: { icon: "📊", color: "#2ecc71" },
    img: { icon: "🖼️", color: "#e07cf7" },
    vid: { icon: "🎬", color: "#f7924f" },
  };
  const { icon, color } = map[type] || { icon: "📎", color: COLORS.textSecondary };
  return <span style={{ fontSize: 22, filter: `drop-shadow(0 0 4px ${color}88)` }}>{icon}</span>;
}

function Tag({ label, color }) {
  return (
    <span style={{
      padding: "2px 10px", borderRadius: 99, fontSize: 11, fontWeight: 600,
      background: color + "22", color: color, border: `1px solid ${color}44`,
      fontFamily: "'DM Mono', monospace", letterSpacing: "0.04em",
    }}>{label}</span>
  );
}

function formatTime(iso) {
  const d = new Date(iso);
  return d.toLocaleDateString("de-DE", { day: "2-digit", month: "short" }) + " · " +
    d.toLocaleTimeString("de-DE", { hour: "2-digit", minute: "2-digit" });
}

// ─── LOGIN ────────────────────────────────────────────────────────────────────
function LoginPage({ onLogin }) {
  const [username, setUsername] = useState("");
  const [password, setPassword] = useState("");
  const [error, setError] = useState("");
  const [loading, setLoading] = useState(false);

  function handleLogin() {
    setLoading(true);
    setTimeout(() => {
      const key = username.trim().toLowerCase();
      if (CREDENTIALS[key] && CREDENTIALS[key] === password) {
        const userMap = { anna: 1, ben: 2, clara: 3, david: 4 };
        onLogin(USERS[userMap[key] - 1]);
      } else {
        setError("Ungültige Anmeldedaten. Versuche: anna / 1234");
        setLoading(false);
      }
    }, 700);
  }

  return (
    <div style={{
      minHeight: "100vh", background: COLORS.bg, display: "flex",
      alignItems: "center", justifyContent: "center",
      fontFamily: "'DM Sans', sans-serif",
    }}>
      <div style={{ position: "absolute", inset: 0, overflow: "hidden", pointerEvents: "none" }}>
        <div style={{
          position: "absolute", top: "20%", left: "50%", transform: "translateX(-50%)",
          width: 600, height: 600, borderRadius: "50%",
          background: "radial-gradient(circle, rgba(79,142,247,0.08) 0%, transparent 70%)",
        }} />
      </div>

      <div style={{
        width: 400, background: COLORS.surface, border: `1px solid ${COLORS.border}`,
        borderRadius: 20, padding: 40, position: "relative",
        boxShadow: `0 24px 80px rgba(0,0,0,0.5), 0 0 0 1px rgba(79,142,247,0.08)`,
      }}>
        <div style={{ textAlign: "center", marginBottom: 36 }}>
          <div style={{
            width: 56, height: 56, borderRadius: 16,
            background: `linear-gradient(135deg, ${COLORS.accent}, #7b4ff7)`,
            display: "flex", alignItems: "center", justifyContent: "center",
            fontSize: 26, margin: "0 auto 16px", boxShadow: `0 8px 24px ${COLORS.accent}44`,
          }}>⬡</div>
          <div style={{ fontSize: 24, fontWeight: 700, color: COLORS.textPrimary, letterSpacing: "-0.03em" }}>
            Projekt<span style={{ color: COLORS.accent }}>Hub</span>
          </div>
          <div style={{ color: COLORS.textSecondary, fontSize: 13, marginTop: 6 }}>
            Melde dich an, um auf dein Team-Dashboard zuzugreifen
          </div>
        </div>

        <div style={{ display: "flex", flexDirection: "column", gap: 14 }}>
          <input
            placeholder="Benutzername"
            value={username}
            onChange={e => setUsername(e.target.value)}
            onKeyDown={e => e.key === "Enter" && handleLogin()}
            style={{
              background: COLORS.bg, border: `1px solid ${COLORS.border}`,
              borderRadius: 10, padding: "12px 16px", color: COLORS.textPrimary,
              fontSize: 14, outline: "none", fontFamily: "'DM Sans', sans-serif",
            }}
          />
          <input
            type="password"
            placeholder="Passwort"
            value={password}
            onChange={e => setPassword(e.target.value)}
            onKeyDown={e => e.key === "Enter" && handleLogin()}
            style={{
              background: COLORS.bg, border: `1px solid ${COLORS.border}`,
              borderRadius: 10, padding: "12px 16px", color: COLORS.textPrimary,
              fontSize: 14, outline: "none", fontFamily: "'DM Sans', sans-serif",
            }}
          />
          {error && <div style={{ color: COLORS.danger, fontSize: 12, padding: "8px 12px", background: "#e74c3c11", borderRadius: 8 }}>{error}</div>}
          <button
