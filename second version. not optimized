// ─── DASHBOARD ────────────────────────────────────────────────────────────────
function Dashboard({ tasks }) {
  const overall = Math.round(tasks.reduce((s, t) => s + t.progress, 0) / tasks.length);
  const overallColor = overall >= 75 ? COLORS.success : overall >= 40 ? COLORS.warning : COLORS.danger;

  return (
    <div style={{ display: "flex", flexDirection: "column", gap: 28 }}>
      <div>
        <h1 style={{ fontSize: 26, fontWeight: 800, color: COLORS.textPrimary, margin: 0, letterSpacing: "-0.03em" }}>Dashboard</h1>
        <p style={{ color: COLORS.textSecondary, margin: "4px 0 0", fontSize: 14 }}>Projektüberblick & aktueller Status</p>
      </div>

      <div style={{
        background: COLORS.surface, borderRadius: 16, border: `1px solid ${COLORS.border}`,
        padding: 28, position: "relative", overflow: "hidden",
      }}>
        <div style={{
          position: "absolute", top: -30, right: -30, width: 160, height: 160, borderRadius: "50%",
          background: `radial-gradient(circle, ${overallColor}18 0%, transparent 70%)`,
        }} />
        <div style={{ display: "flex", alignItems: "center", justifyContent: "space-between", marginBottom: 18 }}>
          <div>
            <div style={{ fontSize: 13, color: COLORS.textMuted, fontFamily: "'DM Mono', monospace", letterSpacing: "0.06em" }}>GESAMTFORTSCHRITT</div>
            <div style={{ fontSize: 44, fontWeight: 900, color: overallColor, letterSpacing: "-0.04em", lineHeight: 1.1, marginTop: 4 }}>
              {overall}<span style={{ fontSize: 24 }}>%</span>
            </div>
          </div>
          <div style={{ textAlign: "right" }}>
            <Tag label={overall >= 75 ? "IM PLAN" : overall >= 40 ? "IN ARBEIT" : "VERZÖGERUNG"} color={overallColor} />
            <div style={{ fontSize: 12, color: COLORS.textSecondary, marginTop: 8 }}>{tasks.length} aktive Aufgabenbereiche</div>
          </div>
        </div>
        <ProgressBar value={overall} color={overallColor} />
      </div>

      <div style={{ background: COLORS.surface, borderRadius: 16, border: `1px solid ${COLORS.border}`, padding: 24 }}>
        <div style={{ fontSize: 15, fontWeight: 700, color: COLORS.textPrimary, marginBottom: 20 }}>Aufgabenbereiche</div>
        <div style={{ display: "flex", flexDirection: "column", gap: 18 }}>
          {tasks.map(task => {
            const c = task.progress >= 80 ? COLORS.success : task.progress >= 50 ? COLORS.accent : task.progress >= 25 ? COLORS.warning : COLORS.danger;
            return (
              <div key={task.id}>
                <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 8 }}>
                  <div>
                    <span style={{ fontSize: 14, fontWeight: 600, color: COLORS.textPrimary }}>{task.label}</span>
                    <span style={{ fontSize: 12, color: COLORS.textMuted, marginLeft: 10 }}>{task.owner}</span>
                  </div>
                  <span style={{ fontSize: 13, fontWeight: 700, color: c, fontFamily: "'DM Mono', monospace" }}>{task.progress}%</span>
                </div>
                <ProgressBar value={task.progress} color={c} thin />
              </div>
            );
          })}
        </div>
      </div>

      <div style={{ background: COLORS.surface, borderRadius: 16, border: `1px solid ${COLORS.border}`, padding: 24 }}>
        <div style={{ fontSize: 15, fontWeight: 700, color: COLORS.textPrimary, marginBottom: 18 }}>Team</div>
        <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 12 }}>
          {USERS.map(u => (
